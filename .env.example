# Copy to .env and fill in real values. .env is gitignored.
#
# These are consumed by docker-compose.yml. Foragent and the RockBot agent can
# be pointed at different models — Foragent uses FORAGENT_LLM_* for its own
# LLM-backed capabilities (extract-structured-data and beyond), the RockBot
# agent uses LLM_* for its own reasoning.
#
# Direct curl tests of capabilities that don't need an LLM (fetch-page-title)
# still work without either set; anything LLM-backed will fail until Foragent's
# config is populated.

# ── Foragent's LLM (REQUIRED for extract-structured-data) ────────────────────
# Azure AI Foundry / OpenAI-compatible endpoints are both fine.
# Foundry endpoint shape: https://<resource>-<region>.cognitiveservices.azure.com/openai/v1/
FORAGENT_LLM_ENDPOINT=https://your-resource-region.cognitiveservices.azure.com/openai/v1/
FORAGENT_LLM_MODEL_ID=gpt-5.3-chat
FORAGENT_LLM_API_KEY=replace-with-your-key

# ── RockBot agent's LLM (only affects the rockbot service in docker-compose) ──
# RockBot falls back to EchoChatClient without these; the HTTP smoke-tests in
# docker-compose.yml still work, but RockBot can't reason its way to
# invoke_agent without a real model.
LLM_ENDPOINT=https://your-resource-region.cognitiveservices.azure.com/openai/v1/
LLM_MODEL_ID=gpt-5.3-chat
LLM_API_KEY=replace-with-your-key
LLM_PROVIDER=

# ── Agent config ─────────────────────────────────────────────────────────────
AGENT_TIMEZONE=America/Chicago

# ── Optional: Bluesky credentials for post-to-site ───────────────────────────
# Leave empty to disable Bluesky posting end-to-end (post-to-site will respond
# "Credential '…' is not configured"). Use a Bluesky app password from
# https://bsky.app/settings/app-passwords, never your account password.
# Stored only in-process by Foragent's InMemoryCredentialBroker — never logged,
# never sent over A2A. For prod, swap in a k8s-secrets or vault broker.
FORAGENT_BLUESKY_IDENTIFIER=
FORAGENT_BLUESKY_APP_PASSWORD=

# ── Optional ─────────────────────────────────────────────────────────────────
# Only needed if RockBot is configured to use GitHub Copilot / GitHub Models.
GITHUB_TOKEN=
