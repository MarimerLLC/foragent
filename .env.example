# Copy to .env and fill in real values. .env is gitignored.
#
# These are consumed by docker-compose.yml and passed into the `rockbot` service.
# Foragent itself does not use an LLM in step 1 — these only affect the RockBot
# agent's ability to reason about invoking Foragent as an A2A peer.
#
# Without valid LLM config, RockBot falls back to EchoChatClient and cannot call
# tools (including invoke_agent). The direct curl smoke-test at the top of
# docker-compose.yml still works without these — it bypasses RockBot entirely.

# ── LLM (Balanced tier — what RockBot uses for most reasoning) ───────────────
# Azure AI Foundry / OpenAI-compatible endpoints are both fine.
# Foundry endpoint looks like: https://<resource>-<region>.cognitiveservices.azure.com/openai/v1/
LLM_ENDPOINT=https://your-resource-region.cognitiveservices.azure.com/openai/v1/
LLM_MODEL_ID=gpt-5.3-chat
LLM_API_KEY=replace-with-your-key

# Optional — some RockBot setups look at this. Leave blank for OpenAI-compatible endpoints.
LLM_PROVIDER=

# ── Agent config ─────────────────────────────────────────────────────────────
AGENT_TIMEZONE=America/Chicago

# ── Optional ─────────────────────────────────────────────────────────────────
# Only needed if RockBot is configured to use GitHub Copilot / GitHub Models.
GITHUB_TOKEN=
